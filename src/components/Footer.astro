<footer class="site-footer">
  <div class="footer-container">
    <div class="contact-info">
      <h3>Contact Us</h3>
      <p>
        <a href="mailto:info@laurievillefarms.com">info@laurievillefarms.com</a>
      </p>
      <div class="phone-info">
        <a href="tel:8104746639" class="phone-primary">(810) 47-HONEY</a>
        <a href="tel:8104746639" class="phone-secondary">(810) 474-6639</a>
      </div>
    </div>
    
    <div class="footer-links">
      <h3>Quick Links</h3>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/coming-soon">Honey & Sweets</a></li>
        <li><a href="/coming-soon">Beeswax & Candles</a></li>
        <li><a href="/coming-soon">Beekeeping Supplies</a></li>
        <li><a href="/coming-soon">Find Us</a></li>
        <li><a href="/coming-soon">About</a></li>
      </ul>
    </div>
  </div>
  <div class="copyright">
    <p>&copy; {new Date().getFullYear()} Laurieville Farms. All rights reserved.</p>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-charcoal);
    color: var(--color-cream);
    padding: 3rem 1rem 1rem;
    margin-top: 4rem;
  }
  
  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  
  @media (min-width: 768px) {
    .footer-container {
      grid-template-columns: 1fr 1fr;
    }
  }
  
  h3 {
    color: var(--color-gold);
    font-family: var(--font-serif);
    margin-bottom: 1.5rem;
  }
  
  a {
    color: var(--color-cream);
    text-decoration: none;
    transition: color 0.2s ease-in-out;
  }
  
  a:hover {
    color: var(--color-gold);
    text-decoration: underline;
  }
  
  .phone-info {
    display: flex;
    flex-direction: column;
    margin-top: 1rem;
    gap: 0.25rem;
  }
  
  .phone-primary {
    font-size: 1.25rem;
    font-weight: bold;
    color: var(--color-gold);
  }
  
  .phone-primary:hover {
    color: var(--color-cream);
  }
  
  .phone-secondary {
    font-size: 0.9rem;
    opacity: 0.8;
  }
  
  .footer-links ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  
  .footer-links li {
    margin-bottom: 0.5rem;
  }
  
  .copyright {
    text-align: center;
    margin-top: 3rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255,253,247,0.1);
    font-size: 0.85rem;
    opacity: 0.8;
  }
</style>
