---
// src/components/Footer.astro
import catalogData from '../data/products.json';

// Dynamically extract categories to perfectly sync the footer navigation to the Master JSON
const uniqueCategories = [...new Set(catalogData.products.map((p: any) => p.category))];

const categoryLabels: Record<string, string> = {
  'honey': 'Honey & Sweets',
  'candles': 'Beeswax & Candles',
  'woodenware': 'Beekeeping Supplies'
};
---
<footer class="site-footer">
  <div class="footer-container">
    <div class="contact-info">
      <h3>Contact Us</h3>
      <p>
        <a href="mailto:info@laurievillefarms.com">info@laurievillefarms.com</a>
      </p>
      <div class="phone-info">
        <a href="tel:8104746639" class="phone-primary">(810) 47-HONEY</a>
        <a href="tel:8104746639" class="phone-secondary">(810) 474-6639</a>
      </div>
    </div>
    
    <div class="footer-links">
      <h3>Quick Links</h3>
      <ul>
        <li><a href="/">Home</a></li>
        {uniqueCategories.map(cat => (
          <li><a href={`/products/${cat}`}>{categoryLabels[cat] || cat.charAt(0).toUpperCase() + cat.slice(1)}</a></li>
        ))}
        <li><a href="/coming-soon">Find Us</a></li>
        <li><a href="/info">About</a></li>
      </ul>
    </div>
    
    <div class="social-footer">
      <h3>Follow Us</h3>
      <div class="social-icons">
        <a href="https://www.instagram.com/laurievillefarms/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
          <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" class="icon"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
        </a>
        <a href="https://www.tiktok.com/@laurievillefarms" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
          <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" class="icon"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path></svg>
        </a>
        <a href="https://www.youtube.com/@LaurievilleFarms" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
          <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" class="icon"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"></path><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon></svg>
        </a>
        <a href="https://www.facebook.com/LaurievilleFarms" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
          <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" class="icon"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
        </a>
      </div>
    </div>
  </div>
  <div class="copyright">
    <p>&copy; {new Date().getFullYear()} Laurieville Farms. All rights reserved.</p>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-charcoal);
    color: var(--color-cream);
    padding: 3rem 1rem 1rem;
    margin-top: 4rem;
  }
  
  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  
  @media (min-width: 768px) {
    .footer-container {
      grid-template-columns: 1fr 1fr 1fr;
    }
  }
  
  h3 {
    color: var(--color-gold);
    font-family: var(--font-serif);
    margin-bottom: 1.5rem;
  }
  
  a {
    color: var(--color-cream);
    text-decoration: none;
    transition: color 0.2s ease-in-out;
  }
  
  a:hover {
    color: var(--color-gold);
    text-decoration: underline;
  }
  
  .phone-info {
    display: flex;
    flex-direction: column;
    margin-top: 1rem;
    gap: 0.25rem;
  }
  
  .phone-primary {
    font-size: 1.25rem;
    font-weight: bold;
    color: var(--color-gold);
  }
  
  .phone-primary:hover {
    color: var(--color-cream);
  }
  
  .phone-secondary {
    font-size: 0.9rem;
    opacity: 0.8;
  }
  
  .footer-links ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  
  .footer-links li {
    margin-bottom: 0.5rem;
  }
  
  .copyright {
    text-align: center;
    margin-top: 3rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255,253,247,0.1);
    font-size: 0.85rem;
    opacity: 0.8;
  }
  
  .social-icons {
    display: flex;
    gap: 1rem;
  }
  
  .icon {
    transition: stroke 0.2s ease, transform 0.2s ease;
  }

  .social-icons a:hover .icon {
    stroke: var(--color-gold);
    transform: translateY(-2px);
  }
</style>
