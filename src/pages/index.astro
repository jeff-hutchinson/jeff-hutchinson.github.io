---
import BaseLayout from '../layouts/BaseLayout.astro';
const farmName = "Laurieville Farms";
---
<BaseLayout title={farmName}>
  <section class="hero-section">
    <h1>Welcome to {farmName}</h1>
    <p>Coming soon: Pure Michigan Honey & Handcrafted Supplies.</p>
  </section>
</BaseLayout>

<style>
  .hero-section {
    padding: 4rem 0;
    text-align: center;
  }
  
  .hero-section h1 {
    font-size: 2.5rem;
    color: var(--color-gold);
    margin-bottom: 1rem;
  }
  
  .hero-section p {
    font-size: 1.25rem;
  }
</style>