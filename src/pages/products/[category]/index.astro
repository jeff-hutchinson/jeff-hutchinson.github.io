---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ProductCard from '../../../components/ProductCard.astro';
import catalogData from '../../../data/products.json';
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

// Astro's SSG function to generate the raw URLs mathematically
export function getStaticPaths() {
  // Extract all unique categories directly from the products array natively
  const uniqueCategories = [...new Set(catalogData.products.map((p: any) => p.category))];
  
  return uniqueCategories.map((cat) => ({
    params: { category: cat },
    props: { 
      categoryData: { header: `Explore our premium collection of handcrafted ${cat}.` },
      products: catalogData.products.filter((p: any) => p.category === cat)
    }
  }));
}

const { category } = Astro.params;
const { categoryData, products } = Astro.props;

// Formatting the title cleanly (e.g., 'woodenware' -> 'Woodenware')
const title = category.charAt(0).toUpperCase() + category.slice(1);

// Map specific hero images to generic category names dynamically
const localImages = import.meta.glob<{ default: ImageMetadata }>('/src/assets/*.{jpeg,jpg,png,gif}');
const categoryHeroMap: Record<string, string> = {
  'woodenware': '/src/assets/covers.jpg',
  'honey': '/src/assets/honey-jar.jpg',
  'candles': '/src/assets/candle.jpg'
};
const heroImageUrl = categoryHeroMap[category.toLowerCase()] || '/src/assets/hero.jpg';
const heroImagePromise = localImages[heroImageUrl];
---

<BaseLayout pageTitle={`${title} | Laurieville Farms`}>
  {/* Utilizing the established 'Split-Block' High Contrast Hero rule */}
  <section class="category-hero page-hero">
    <div class="hero-content">
      <h1>{title}</h1>
      <p class="category-description">{categoryData.header}</p>
    </div>
    <div class="hero-image-container">
      {heroImagePromise && (
        <Image src={heroImagePromise()} alt={`${title} cover image`} width={800} format="webp" loading="eager" decoding="async" class="hero-img" />
      )}
    </div>
  </section>

  <section class="products-grid wrapper">
    {products.length > 0 ? (
      <div class="grid-container">
        {products.map(product => (
          <ProductCard product={product} />
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <p>New {title.toLowerCase()} arriving soon! Please check back later or contact us directly.</p>
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .category-hero {
    /* Impact Zone: Charcoal Background */
    background-color: var(--color-charcoal, #212121);
    color: var(--color-cream, #fffdf7);
    padding: 3rem 1.5rem;
    text-align: left;
    margin-bottom: 3rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 3rem;
  }
  
  .hero-content {
    flex: 1;
    min-width: 300px;
    max-width: 600px;
  }

  .hero-image-container {
    flex: 1;
    min-width: 300px;
    max-width: 500px;
    aspect-ratio: 4 / 3; /* Mandates uniform template sizing across all pages */
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 12px 36px rgba(0,0,0,0.4);
    border: 4px solid var(--color-cream, #fffdf7);
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  
  .hero-content h1 {
    font-family: var(--font-serif, "Georgia", serif);
    font-size: 3.5rem;
    margin: 0 0 1rem 0;
    color: var(--color-cream, #fffdf7);
    letter-spacing: 0.02em;
  }
  
  .category-description {
    font-size: 1.25rem;
    color: var(--color-gold, #E8A50E); 
    line-height: 1.6;
  }

  .wrapper {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem 6rem;
  }

  /* Structural UI Rule: Mobile-first 1-column stacking */
  .grid-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  /* Tablet view: 2 columns */
  @media (min-width: 768px) {
    .grid-container {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Desktop view: 3 columns */
  @media (min-width: 1024px) {
    .grid-container {
      grid-template-columns: repeat(3, 1fr);
      gap: 3rem;
    }
  }

  .empty-state {
    text-align: center;
    padding: 4rem 2rem;
    background-color: #f7f3ec; /* Cream derivative */
    border: 1px dashed var(--color-charcoal, #212121);
    border-radius: 8px;
    color: var(--color-charcoal, #212121);
    font-style: italic;
  }
</style>
