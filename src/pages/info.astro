---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import innerCoverHero from '../assets/inner-cover.jpg';

// Placeholders for social URLs until the user provides them
const socialLinks = {
  instagram: '#',
  tiktok: '#',
  youtube: '#',
  facebook: '#'
};
---

<BaseLayout title="Info & About - Laurieville Farms">
  <!-- Hero Section -->
  <section class="page-hero">
    <div class="hero-bg-wrapper">
      <Image src={innerCoverHero} alt="Laurieville Farms Inner Cover" class="hero-img" width={1920} />
      <div class="hero-overlay"></div>
    </div>
    <div class="hero-content">
      <h1>About Our Farm</h1>
    </div>
  </section>

  <!-- Info Content -->
  <section class="info-content container">
    <div class="content-block">
      <!-- Placeholder for the Maps Description -->
      <p class="lead-text">
        We are a sustainable beekeeping operation dedicated to producing raw, unfiltered honey and high-quality hive products right here in Michigan. Our mission is to support healthy pollinators, steward the land responsibly, and offer honey that reflects the unique seasonal blooms of our region.

At the heart of our work is a commitment to community. We aim to connect people to the source of their food, raise awareness about the importance of bees, and build a vibrant local network around Michigan-grown honey and beekeeping practices.
      </p>
    </div>

    <!-- Stay Connected Section -->
    <div class="content-block stay-connected">
      <h2>Stay Connected</h2>
      <p>Follow our journey and see what the bees are up to!</p>
      
      <div class="social-links-grid">
        <a href={socialLinks.instagram} target="_blank" rel="noopener noreferrer" class="social-btn">
          Instagram
        </a>
        <a href={socialLinks.tiktok} target="_blank" rel="noopener noreferrer" class="social-btn">
          TikTok
        </a>
        <a href={socialLinks.youtube} target="_blank" rel="noopener noreferrer" class="social-btn">
          YouTube
        </a>
        <a href={socialLinks.facebook} target="_blank" rel="noopener noreferrer" class="social-btn">
          Facebook
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    position: relative;
    min-height: 40vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: var(--color-cream);
    overflow: hidden;
    margin-bottom: 4rem;
  }

  .hero-bg-wrapper {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(33, 33, 33, 0.5);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    padding: 2rem;
  }

  .hero-content h1 {
    font-size: 3rem;
    color: var(--color-gold);
    margin-bottom: 0.5rem;
    text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
  }

  .info-content {
    max-width: 800px;
    margin: 0 auto;
  }

  .content-block {
    margin-bottom: 4rem;
  }

  .lead-text {
    font-size: 1.25rem;
    line-height: 1.8;
    color: var(--color-charcoal);
  }

  .stay-connected {
    background-color: white;
    padding: 3rem 2rem;
    border-radius: 8px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    text-align: center;
    border-top: 4px solid var(--color-gold);
  }

  .stay-connected h2 {
    color: var(--color-charcoal);
    margin-bottom: 0.5rem;
  }

  .stay-connected p {
    margin-bottom: 2rem;
    color: #666;
  }

  .social-links-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    max-width: 500px;
    margin: 0 auto;
  }

  @media (min-width: 600px) {
    .social-links-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .social-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-cream);
    color: var(--color-charcoal);
    padding: 1rem;
    border-radius: 4px;
    font-weight: bold;
    border: 1px solid rgba(0,0,0,0.1);
    transition: all 0.2s ease;
  }

  .social-btn:hover {
    background-color: var(--color-charcoal);
    color: var(--color-cream);
    text-decoration: none;
    transform: translateY(-2px);
    border-color: var(--color-charcoal);
  }
</style>
