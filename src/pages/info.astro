---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import beeHivesHero from '../assets/bee-hives.jpg';

const socialLinks = {
  instagram: 'https://www.instagram.com/laurievillefarms/',
  tiktok: 'https://www.tiktok.com/@laurievillefarms',
  youtube: 'https://www.youtube.com/@LaurievilleFarms',
  facebook: 'https://www.facebook.com/LaurievilleFarms'
};
---

<BaseLayout title="Info & About - Laurieville Farms">
  <!-- Hero Section -->
  <section class="page-hero">
    <div class="hero-bg-wrapper">
      <Image src={beeHivesHero} alt="Laurieville Farms Bee Hives" class="hero-img" width={1920} />
      <div class="hero-overlay"></div>
    </div>
    <div class="hero-content">
      <h1>About Our Farm</h1>
    </div>
  </section>

  <!-- Info Content -->
  <section class="info-content container">
    <div class="content-block about-description">
      <p class="lead-text">
        We are a sustainable beekeeping operation dedicated to producing raw, unfiltered honey and high-quality hive products right here in Michigan. Our mission is to support healthy pollinators, steward the land responsibly, and offer honey that reflects the unique seasonal blooms of our region.
      </p>
      <p class="lead-text">
        At the heart of our work is a commitment to community. We aim to connect people to the source of their food, raise awareness about the importance of bees, and build a vibrant local network around Michigan-grown honey and beekeeping practices.
      </p>
    </div>

    <!-- Stay Connected Section -->
    <div class="content-block stay-connected">
      <h2>Stay Connected</h2>
      <p>Follow our journey and see what the bees are up to!</p>
      
      <div class="social-links-grid">
        <a href={socialLinks.instagram} target="_blank" rel="noopener noreferrer" class="social-btn instagram">
          <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" class="social-icon"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
          Instagram
        </a>
        <a href={socialLinks.tiktok} target="_blank" rel="noopener noreferrer" class="social-btn tiktok">
          <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" class="social-icon"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path></svg>
          TikTok
        </a>
        <a href={socialLinks.youtube} target="_blank" rel="noopener noreferrer" class="social-btn youtube">
          <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" class="social-icon"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"></path><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon></svg>
          YouTube
        </a>
        <a href={socialLinks.facebook} target="_blank" rel="noopener noreferrer" class="social-btn facebook">
          <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" class="social-icon"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
          Facebook
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    display: flex;
    flex-direction: column;
    margin-bottom: 4rem;
  }

  .hero-bg-wrapper {
    position: relative;
    width: 100%;
    height: 40vh;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(33, 33, 33, 0.35);
  }

  .hero-content {
    background-color: var(--color-charcoal);
    padding: 1.5rem 2rem;
    text-align: center;
    color: var(--color-cream);
  }

  .hero-content h1 {
    font-size: 3rem;
    color: var(--color-gold);
    margin: 0;
  }

  .info-content {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .about-description {
    background-color: white;
    padding: 3rem;
    border-radius: 8px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    border-top: 4px solid var(--color-gold);
    margin-top: 4rem;
    position: relative;
  }

  .content-block {
    margin-bottom: 4rem;
  }

  .lead-text {
    font-size: 1.25rem;
    line-height: 1.8;
    color: var(--color-charcoal);
    margin-bottom: 1.5rem;
  }
  
  .lead-text:last-child {
    margin-bottom: 0;
  }

  .stay-connected {
    background-color: white;
    padding: 3rem 2rem;
    border-radius: 8px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    text-align: center;
    border-top: 4px solid var(--color-gold);
  }

  .stay-connected h2 {
    color: var(--color-charcoal);
    margin-bottom: 0.5rem;
  }

  .stay-connected p {
    margin-bottom: 2rem;
    color: #666;
  }

  .social-links-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    max-width: 700px;
    margin: 0 auto;
  }

  @media (min-width: 600px) {
    .social-links-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .social-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    background-color: var(--color-cream);
    color: var(--color-charcoal);
    padding: 1.25rem;
    border-radius: 50px; /* Pill shape for inviting feel */
    font-weight: bold;
    font-size: 1.1rem;
    border: 2px solid var(--color-gold);
    box-shadow: 0 4px 6px rgba(0,0,0,0.05);
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  }
  
  .social-icon {
    transition: transform 0.3s ease;
  }

  .social-btn:hover {
    color: white;
    text-decoration: none;
    transform: translateY(-4px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.1);
  }
  
  .social-btn:hover .social-icon {
    transform: scale(1.1);
  }

  /* Artistic freedom: Brand colors on hover */
  .social-btn.instagram:hover {
    background: linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%);
  }
  
  .social-btn.tiktok:hover {
    background-color: #000000;
  }
  
  .social-btn.youtube:hover {
    background-color: #FF0000;
  }
  
  .social-btn.facebook:hover {
    background-color: #1877F2;
  }
</style>
