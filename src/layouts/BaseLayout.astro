---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const { title = "Laurieville Farms" } = Astro.props;
---

<html lang="en">
  <head>
    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-ZXPQ9XHED3"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-ZXPQ9XHED3');
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "Laurieville Farms",
        "image": "https://laurievillefarms.com/images/logo.png",
        "@id": "https://laurievillefarms.com",
        "url": "https://laurievillefarms.com",
        "telephone": "+18104746639",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "3957 Kim Ct.",
          "addressLocality": "Otter Lake",
          "addressRegion": "MI",
          "postalCode": "48464",
          "addressCountry": "US"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": 43.2811,
          "longitude": -83.5305
        },
        "publicAccess": false,
        "description": "Michigan-based apiary specializing in raw honey, beeswax candles, and custom beekeeping woodenware. All visits are by appointment only.",
        "sameAs": [
          "https://www.facebook.com/LaurievilleFarms",
          "https://www.instagram.com/laurievillefarms",
          "https://www.tiktok.com/@laurievillefarms",
          "https://www.youtube.com/@LaurievilleFarms"
        ],
        "contactPoint": {
          "@type": "ContactPoint",
          "telephone": "+18104746639",
          "contactType": "customer service",
          "availableLanguage": "en"
        }
      }
</script>
  </head>
  <body>
    <Header />
    <main class="container">
      <slot />
    </main>
    <Footer />
  </body>
</html>
